# --- CiteLoop API (Go) ---
DATABASE_URL=postgres://postgres:citeloop@localhost:5432/citeloop?sslmode=disable
PORT=8080

# LLM provider. TokenGate's OpenAI-compatible gateway is preferred when
# TOKENGATE_API_KEY is set. The base URL must include /v1.
TOKENGATE_API_KEY=
TOKENGATE_BASE_URL=https://tokengate-production.up.railway.app/v1
TOKENGATE_MODEL=claude-haiku-4-5-20251001

# Claude fallback (used only when TOKENGATE_API_KEY is empty)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Clerk auth. When CLERK_SECRET_KEY is set, /api/* requires a Clerk session
# Bearer token. /healthz remains public.
CLERK_SECRET_KEY=

# Search provider (Brave by default; falls back to mock when empty)
SEARCH_API_KEY=

# BlogPublisher — §8 option A: MDX-in-repo, auto-commit via GitHub Contents API.
# When GITHUB_TOKEN or BLOG_REPO is empty the publisher runs in dry-run (logs,
# computes the URL, does NOT commit) so the pipeline is demonstrable.
GITHUB_TOKEN=
BLOG_REPO=owner/blog-repo
BLOG_BRANCH=citeloop-content
BLOG_CONTENT_DIR=content/citeloop/blog
BLOG_BASE_URL=https://unipost.example/blog
# Required for UniPost build-time content loaders to rebuild after CiteLoop commits.
UNIPOST_DEPLOY_HOOK_URL=

# Notification webhooks are encrypted at rest with this app-level key material.
NOTIFICATION_SECRET_KEY=
