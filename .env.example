# --- CiteLoop API (Go) ---
DATABASE_URL=postgres://postgres:citeloop@localhost:5432/citeloop?sslmode=disable
PORT=8080

# LLM provider (real Claude when set; falls back to deterministic mock when empty)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Search provider (Brave by default; falls back to mock when empty)
SEARCH_API_KEY=

# BlogPublisher — §8 option A: MDX-in-repo, auto-commit via GitHub Contents API.
# When GITHUB_TOKEN or BLOG_REPO is empty the publisher runs in dry-run (logs,
# computes the URL, does NOT commit) so the pipeline is demonstrable.
GITHUB_TOKEN=
BLOG_REPO=owner/blog-repo
BLOG_BRANCH=content-publish
BLOG_BASE_URL=https://unipost.example/blog
